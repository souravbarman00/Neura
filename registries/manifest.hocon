{
    # ---- User-facing assistants ----
    "neura.hocon": true,
    # Research Radar — personal literature scout (chattable + powers the Radar panel).
    "research_radar.hocon": true,
    # The real agent-network designer (from neuro-san-studio / alive). Talkable + used to spawn.
    "agent_network_designer.hocon": true,

    # ---- Internal support networks (served, not listed publicly) ----
    "memory_compressor.hocon":              { "serve": true, "public": false },
    "agent_network_editor.hocon":           { "serve": true, "public": false },
    "agent_network_instructions_editor.hocon": { "serve": true, "public": false },
    "agent_network_query_generator.hocon":  { "serve": true, "public": false },
    "agent_network_architect.hocon":        { "serve": true, "public": false },
    "agent_network_test_generator.hocon":   { "serve": true, "public": false },

    # ---- Dynamically-spawned networks (written by the designer at runtime) ----
    include "registries/generated/manifest.hocon"
}
