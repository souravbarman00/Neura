# Neura — copy this to `.env` and fill in your key(s).

# LLM provider key — set the one matching your active provider in
# config/llm_config.hocon. Anthropic is the default.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...        # if class = "openai"
# MISTRAL_API_KEY=...          # if class = "langchain_mistralai.chat_models.ChatMistralAI"

# --- Optional overrides ---
# Where the local vector store lives (default: ./data/chroma)
# NEURA_CHROMA_DIR=./data/chroma
# Which collection to use (default: about_me)
# NEURA_COLLECTION=about_me
# Port the neuro-san server listens on (default: 8099)
# NEURA_HTTP_PORT=8099
