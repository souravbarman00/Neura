{
    # LLM for every agent in the Neura network. Managed by the Settings → Model
    # tab in the UI (POST /api/llm). Edit there, or swap the active block below.
    #
    #   Anthropic / OpenAI: native neuro-san classes (use "model_name").
    #   Mistral: wired via ChatMistralAI (uses "model").

    # --- Active: Mistral AI ---
    "llm_config": {
        "class": "langchain_mistralai.chat_models.ChatMistralAI",
        "model": "mistral-large-latest",
        "temperature": 0.2
    }

    # --- Preset: Claude (Anthropic) ---
