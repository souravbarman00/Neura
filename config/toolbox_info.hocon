  "google_serper": {
    "class": "toolbox.google_serper.GoogleSerper",
    "description": "Search the web using Google Serper API with customizable parameters.\n        \n        Supports multiple search types (web, news, images, places) with geographic and language localization.\n        Returns structured search results with metadata for easy processing.\n        \n        Available parameters:\n        - query (required): The search term or question to look up online\n        - type (optional): Search type - 'search' (default, general web), 'news', 'images', or 'places'\n        - k (optional): Number of results to return (default: 10)\n        - gl (optional): Country code for geographic localization (default: 'us', e.g., 'uk', 'de', 'fr')\n        - hl (optional): Language code for search interface (default: 'en', e.g., 'es', 'fr', 'de')\n        - tbs (optional): Time-based search filter (e.g., 'qdr:d' for past day, 'qdr:w' for past week, 'qdr:m' for past month)\n        \n        Use this for: real-time web information, news searches, location-based queries, and when you need\n        fresh data not available in the AI model's training data.",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "The search term or question to look up online."
        },
        "type": {
          "type": "string",
          "description": "Type of search: 'search' (general web), 'news', 'images', or 'places'. Default: 'search'"
        },
        "k": {
          "type": "object",
          "description": "Number of search results to retrieve. Default: 10"
        },
        "gl": {
          "type": "string",
          "description": "Country code to localize search results (e.g., 'us', 'uk', 'de'). Default: 'us'"
        },
        "hl": {
          "type": "string",
          "description": "Language code for the search interface (e.g., 'en', 'es', 'fr'). Default: 'en'"
        },
        "tbs": {
          "type": "string",
          "description": "Time-based search filter (e.g., 'qdr:d' for past day, 'qdr:w' for past week, 'qdr:m' for past month)"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  "tavily_search": {
    "class": "langchain_tavily.TavilySearch",
    "base_tool_info_url": "https://pypi.org/project/langchain-tavily/",
    "args": {
      "max_results": 5,
      "topic": "general",
      "include_answer": false,
      "include_raw_content": false,
      "include_images": false,
      "include_image_descriptions": false,
      "include_favicon": false,
      "search_depth": "basic",
      "time_range": "day",
      "include_domains": null,
      "exclude_domains": null,
      "country": null
    }
  },
  "mysql": {
    "class": "mysql.MySqlTool",
    "description": "Execute a single read-only SQL SELECT against the connected MySQL database and return the rows. Discover the schema yourself via information_schema when unknown, e.g. \"SELECT table_name FROM information_schema.tables WHERE table_schema=DATABASE()\" and \"SELECT column_name, data_type FROM information_schema.columns WHERE table_name='<t>'\". NEVER ask the user to run SQL \\u2014 always call this tool. Only SELECT statements are permitted.",
    "parameters": {
      "type": "object",
      "properties": {
        "sql": {
          "type": "string",
          "description": "The SQL query to run."
        }
      },
      "required": [
        "sql"
      ]
    }
  },
