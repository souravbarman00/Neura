{
  "anthropic_search": {
    "class": "toolbox.anthropic_web_search.AnthropicWebSearch",
    "description": "Tool that provides web search capabilities",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "The text to search in."
        }
      },
      "required": [
