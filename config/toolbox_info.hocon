  "wikimedia_media_search": {
    "class": "toolbox.wikimedia_media_search.WikimediaMediaSearch",
    "description": "\n        Searches Wikimedia Commons for media files (images, audio, video) and returns direct URLs with proper file extensions.\nThis tool is excellent for finding high-quality, properly licensed multimedia content from Wikimedia Commons.\nSupports searching for images, audio files (mp3, ogg, flac, wav), and video files (webm, ogv, mp4).\n        ",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "The search query with KEYWORDS ONLY (no conversational phrases). Extract key terms from user request. \n                    Examples: 'nature video' (NOT 'show me nice nature video'), 'Einstein' (NOT 'photos of Einstein'), 'rain sound' (NOT 'find me rain sounds').\n                    For videos, include 'video', 'timelapse', or 'animation'. For audio, include 'sound' or 'audio'."
        },
        "media_type": {
          "type": "string",
          "description": "Type of media to search for: 'image', 'audio', 'video', or 'all' (default: 'image')"
        },
        "limit": {
          "type": "int",
          "description": "Maximum number of results to return (default: 1, maximum: 10)"
        },
        "offset": {
          "type": "int",
          "description": "Result offset for pagination (default: 0). Use 10, 20, 30, etc. to get different sets of results from the same query."
        }
      },
      "required": [
        "query"
      ]
    }
  },
  "arxiv_retriever": {
    "class": "toolbox.arxiv_rag.ArxivRag",
    "description": "This tool retrieves papers from arXiv using a query string.\n\nA query is a text string made of search terms and Boolean operators.\n\nSearch terms must use one of these prefixes:\n\nti = title\nau = author\nabs = abstract\nco = comment\njr = journal reference\ncat = subject category\nrn = report number\nid_list = arXiv article ID\n\nBoolean operators (must be uppercase): AND, OR, ANDNOT\n\nYou can group terms using parentheses ().\n\nExamples:\n\nquery='au:\"del maestro\"'\nquery='au:\"del maestro\" AND ti:checkerboard'\nquery='au:\"del maestro\" AND ti:\"quantum criticality\"'\nquery='au:\"Adrian Del Maestro\" AND au:\"Bernd Rosenow\"'\nquery='au:\"del maestro\" ANDNOT (ti:checkerboard OR ti:Pyrochlore)'\nquery=\"cat:quant-ph AND abs:entanglement\"\nquery=\"id_list:2301.01234\"\n\nRules:\n\n- Every search term must use a prefix\n- Author names with more than one word must be in quotes\n- Boolean operators must be uppercase\n- Use () to group Boolean expressions for Boolean operator precedence.\n- Use double quotes to group multiple words into phrases to search a particular field.\n- Pass the entire query as a single string\n",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Retrieval question to answer over arXiv documents"
        },
        "sort_by": {
          "type": "string",
          "description": "\nA property by which search results can be sorted.\nOptions are `relevance`, `lastUpdatedDate`, and `submittedDate`. Default to `relevance`.\n"
        },
        "sort_order": {
          "type": "string",
          "description": "\nOrder in which search results are sorted according to the specified `sort_by`.\nOptions are `ascending` and `descending`. Default to `descending`.\n"
        },
        "top_k_results": {
          "type": "int",
          "description": "The maximum number of results to be returned in an execution of this search. Default to 3"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  "web_fetch": {
    "class": "toolbox.web_fetch.WebFetch",
    "description": "Fetches the content of a URL and returns its plain-text body along with metadata. Supports HTML pages and PDF documents.",
    "parameters": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "The URL to fetch. Must use http or https scheme and be at most 250 characters."
        },
        "allowed_domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domains to allow. If set, only URLs whose domain matches one of these will be fetched."
        },
        "blocked_domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domains to block. URLs whose domain matches one of these will be rejected."
        },
        "max_content_chars": {
          "type": "int",
          "description": "Maximum number of characters to return from the fetched content. Defaults to 20000."
        }
      },
      "required": [
        "url"
      ]
    }
  },
  "read_file": {
    "class": "toolbox.file_management.read_file.ReadFile",
    "description": "Reads the contents of a local text file (with optional line range and char cap) and returns the text plus metadata. Access is restricted by operator-configured allow/block lists for paths and extensions; the LLM cannot influence those lists.",
    "parameters": {
      "type": "object",
      "properties": {
        "file_path": {
          "type": "string",
          "description": "Absolute or relative path to the file to read."
        },
        "start_line": {
          "type": "int",
          "description": "1-based line number to start reading from. Defaults to 1."
        },
        "end_line": {
          "type": "int",
          "description": "1-based line number to stop reading at (inclusive). Defaults to end of file."
        },
        "max_content_chars": {
          "type": "int",
          "description": "Maximum number of characters to return. Defaults to 20000."
        }
      },
      "required": [
        "file_path"
      ]
    }
  },
