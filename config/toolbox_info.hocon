  "memory_store": {
    "class": "toolbox.memory_store.MemoryTool",
    "description": "Read/write topic-scoped agent memory over the configured memory backend.",
    "parameters": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "The memory operation: 'read', 'write', 'search', 'list', or 'remove'."
        },
        "topic": {
          "type": "string",
          "description": "The topic key to read, write, or remove."
        },
        "content": {
          "type": "string",
          "description": "The content to store (for 'write') or the query text (for 'search')."
        }
